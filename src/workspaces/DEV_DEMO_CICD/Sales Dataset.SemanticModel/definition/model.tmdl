model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["date","product","region","reseller","sales","salesperson"]

annotation PBI_ProTooling = ["DevMode"]

ref table date
ref table product
ref table region
ref table reseller
ref table sales
ref table salesperson

ref cultureInfo en-US

